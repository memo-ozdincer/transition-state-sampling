\@writefile{toc}{\contentsline {subsection}{\numberline {3.4}Why nopath GAD works: self-regulating step size}{3}{subsection.3.4}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Self-regulation mechanism: $|\lambda _0|$ (top), effective $dt$ (middle), and Morse index (bottom) during a typical nopath GAD trajectory. The step size contracts at high $|\lambda _0|$ and expands near the TS.\relax }}{3}{figure.caption.4}\protected@file@percent }
\newlabel{fig:dt-regulation}{{4}{3}{Self-regulation mechanism: $|\eval _0|$ (top), effective $dt$ (middle), and Morse index (bottom) during a typical nopath GAD trajectory. The step size contracts at high $|\eval _0|$ and expands near the TS.\relax }{figure.caption.4}{}}
