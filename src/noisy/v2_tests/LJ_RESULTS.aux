\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Strict vs.\ relaxed convergence rates. \textbf  {Left:} LJ shows a dramatic gap---strict collapses from 92\% to 7\% while relaxed stays above 95\%. \textbf  {Right:} DFTB0 shows no gap (strict $\approx $ relaxed) because ghost modes are absent.}}{3}{figure.1}\protected@file@percent }
