\@writefile{toc}{\contentsline {subsection}{\numberline {4.1}What are ghost modes?}{5}{subsection.4.1}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {4.2}The coin-flip collapse}{5}{subsection.4.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Distribution of $n_\text  {neg}$ (number of negative eigenvalues) at convergence. Green bars = strict ($n_\text  {neg}{=}0$). As noise increases, the distribution shifts right---at $n{=}2.0$, the median sample has $\sim $6 ghost eigenvalues, and only 19 of 285 land at $n_\text  {neg}{=}0$ by chance.}}{6}{figure.4}\protected@file@percent }
\newlabel{fig:nneg}{{4}{6}{Distribution of $n_\text {neg}$ (number of negative eigenvalues) at convergence. Green bars = strict ($n_\text {neg}{=}0$). As noise increases, the distribution shifts right---at $n{=}2.0$, the median sample has $\sim $6 ghost eigenvalues, and only 19 of 285 land at $n_\text {neg}{=}0$ by chance}{figure.4}{}}
