\newlabel{fig:cascade}{{6}{8}{Cascade: convergence rate vs.\ eigenvalue threshold $\tau $. The steep rise from $\tau {=}0$ to $\tau {=}10^{-4}$ shows that most ghost modes have $|\lambda | < 10^{-4}$. The curve plateaus by $\tau {=}2 \times 10^{-3}$}{figure.6}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.5}Hessian conditioning}{9}{subsection.4.5}\protected@file@percent }
\newlabel{sec:conditioning}{{4.5}{9}{Hessian conditioning}{subsection.4.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Hessian condition number $\kappa \approx |\lambda _\text  {max}|/|\lambda _\text  {min}|$ at convergence. $\kappa $ rises $1000\times $ from $n{=}0.5$ to $n{=}2.0$ because ghost eigenvalues ($|\lambda | \sim 10^{-5}$) enter the denominator. Despite $\kappa \sim 10^6$, RFO converges reliably.}}{9}{figure.7}\protected@file@percent }
\newlabel{fig:conditioning}{{7}{9}{Hessian condition number $\kappa \approx |\lambda _\text {max}|/|\lambda _\text {min}|$ at convergence. $\kappa $ rises $1000\times $ from $n{=}0.5$ to $n{=}2.0$ because ghost eigenvalues ($|\lambda | \sim 10^{-5}$) enter the denominator. Despite $\kappa \sim 10^6$, RFO converges reliably}{figure.7}{}}
