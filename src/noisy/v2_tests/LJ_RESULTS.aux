\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Distribution of $\qopname  \relax o{log}_{10}|\lambda _\text  {min}|$ at convergence. Blue = relaxed-converged samples (ghost modes, $\lambda < 0$); green = strict-converged ($\lambda > 0$). Ghost eigenvalues cluster at $|\lambda | \sim 10^{-5}$, far below any physically meaningful curvature.}}{7}{figure.5}\protected@file@percent }
\newlabel{fig:eigenvalue-hist}{{5}{7}{Distribution of $\log _{10}|\lambda _\text {min}|$ at convergence. Blue = relaxed-converged samples (ghost modes, $\lambda < 0$); green = strict-converged ($\lambda > 0$). Ghost eigenvalues cluster at $|\lambda | \sim 10^{-5}$, far below any physically meaningful curvature}{figure.5}{}}
